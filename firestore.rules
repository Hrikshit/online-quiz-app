rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quizzes
    // Fields:
    //   - title: string (1-100 chars)
    //   - subject: string
    //   - description: string (optional, < 500 chars)
    //   - questions: list (1-50 items)
    //   - authorId: string (UID)
    //   - authorName: string
    //   - createdAt: timestamp
    //
    // Collection: activities
    // Fields:
    //   - user: string
    //   - action: string
    //   - avatar: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidQuiz(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.subject is string &&
             data.questions is list && data.questions.size() > 0 && data.questions.size() <= 50 &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.createdAt is number;
    }

    function isValidActivity(data) {
      return data.user is string && data.user.size() > 0 && data.user.size() <= 50 &&
             data.action is string && data.action.size() <= 200 &&
             data.avatar is string &&
             data.createdAt is number;
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
      allow delete: if isOwner(resource.data.authorId);
      allow update: if false; // Quizzes are immutable for now
    }

    match /activities/{activityId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidActivity(request.resource.data);
      allow update, delete: if false;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
